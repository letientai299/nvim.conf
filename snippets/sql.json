{
  "Create table": {
    "prefix": "ct",
    "body": [
      "create table if not exists $1 (",
      "\tid serial primary key,",
      "\t$0",
      "\tstatus int not null default 0,",
      "\t/* creation time, milliseconds since Epoch */",
      "\tctime bigint NOT NULL DEFAULT extract(epoch FROM (timezone('utc', now()))) * 1000,",
      "\t/* modified time, milliseconds since Epoch */",
      "\tmtime bigint NOT NULL DEFAULT extract(epoch FROM (timezone('utc', now()))) * 1000",
      ");"
    ],
    "description": "Create table if not exists"
  },
  "Create translation table": {
    "prefix": "ctr",
