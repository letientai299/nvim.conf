#!/usr/bin/env bash
# fd-based file finder that respects .gitignore but includes specific ignored
# paths. Used by both shell fzf (ctrl-t) and nvim fzf-lua (<leader>ff).
# Keep in sync: dotfiles/bin/fzf-files <-> nvim.conf/scripts/fzf-files
#
# Strategy: three parallel jobs, no dedup needed.
#
#   1. fd (gitignore-aware) for normal files.
#   2. fd --no-ignore --full-path regex for include_dirs and include_dir_globs
#      at any depth (single tree walk with skip_dirs blacklist).
#   3. Bash glob + git check-ignore for include_files at repo root.
#
# (1) skips ignored dirs, (2) only matches paths under an include pattern,
# and (3) only emits files that are actually gitignored — so no dedup needed.
#
# Portability:
#   - fd: Debian/Ubuntu ship it as "fdfind", auto-detected below.
#   - bash 4+: uses arrays (not macOS default bash 3.2, but any
#     mise/homebrew bash works).
set -euo pipefail

# --- Configuration (shared with fzf-dirs, fzf-lua.lua) ----------------------
_cfg="${DOTFILES:-}/config/fzf-includes.sh"
[[ -f "$_cfg" ]] && source "$_cfg" || {
  include_dirs=(.ai.dump .dump)
  include_dir_globs=(local)
  include_files=(.envrc .exrc .nvim.lua .env .env.*)
}

# Heavy dirs to skip during --no-ignore whole-tree scans (step 2).
skip_dirs=(
  node_modules vendor dist build target out bin obj Pods
  .git .svn .hg .tox .venv .env .cache .idea .vscode .DS_Store
  .wxt .playwright-mcp .chrome-profile
)

# --- Detect fd (Debian/Ubuntu install it as fdfind) --------------------------
if command -v fd >/dev/null 2>&1; then
  FD=fd
elif command -v fdfind >/dev/null 2>&1; then
  FD=fdfind
else
  echo "fzf-files: fd not found (install fd-find)" >&2
  exit 1
fi

# --- 1. Base: gitignore-aware ------------------------------------------------
"$FD" --hidden --type f -E .git &

# --- 2. Ignored include dirs at any depth: single regex scan -----------------
# Builds a regex like /(\.ai\.dump|\.dump|local)/ matching any path component.
# Single tree walk; skip_dirs prunes the bulk of ignored content.
{
  parts=()
  for d in "${include_dirs[@]}"; do
    parts+=("$(printf '%s' "$d" | sed 's/[.[\*^$()+?{|\\]/\\&/g')")
  done
  for g in "${include_dir_globs[@]+"${include_dir_globs[@]}"}"; do
    parts+=("$(printf '%s' "$g" | sed 's/[.[\*^$()+?{|\\]/\\&/g')")
  done

  if ((${#parts[@]})); then
    exclude_flags=()
    for d in "${skip_dirs[@]}"; do
      exclude_flags+=(-E "$d")
    done
    alternation="$(IFS='|'; echo "${parts[*]}")"
    "$FD" --no-ignore --hidden --full-path --type f "${exclude_flags[@]}" "/($alternation)/"
  fi
} 2>/dev/null &

# --- 3. Include files at repo root -------------------------------------------
# Only emit those actually gitignored to avoid duplicates with the base fd.
{
  shopt -s nullglob
  for pattern in "${include_files[@]}"; do
    for f in ./$pattern; do
      [[ -f "$f" ]] && printf '%s\n' "${f#./}"
    done
  done | git check-ignore --stdin 2>/dev/null
} 2>/dev/null &

wait
