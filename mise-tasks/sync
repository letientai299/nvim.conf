#!/usr/bin/env bash
#MISE description="Install all tools globally and handle non-mise deps"
set -euo pipefail

# --- Mise tools ---
# Derive tool specs from Lua source and install globally in one call (parallel).
echo "==> Syncing mise tools to global config..."
# shellcheck disable=SC2046
mise use -g $(nvim -l scripts/gen-tools-list.lua)

echo "==> Done."
